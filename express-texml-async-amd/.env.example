# Telnyx API Credentials
TELNYX_API_KEY=your_api_key_here
TELNYX_ACCOUNT_SID=your_account_sid_here
TELNYX_APPLICATION_ID=your_application_id_here

# Telnyx Phone Number (E.164 format)
TELNYX_PHONE_NUMBER=+1234567890

# TeXML Application URL (publicly accessible HTTPS URL)
TEXML_APP_URL=https://your-domain.com:3000/texml

# Server Port
PORT=3000
